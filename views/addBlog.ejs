<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>Create Blog - Blogify</title>
</head>
<body>
<%- include('./partials/nav') %>
<div class="container mt-5">
  <div class="card shadow border-0 p-4 mx-auto"
       style="max-width:700px; border-radius:20px;">
    <h1 class="text-center fw-bold mb-4">
      ✍️ Create New Blog
    </h1>
    <form action="/blog" method="post" enctype="multipart/form-data">
      <div class="mb-4">

        <label for="coverImageURL" class="form-label fw-semibold">
          Cover Image
        </label>

        <input 
          type="file"
          class="form-control"
          id="coverImageURL"
          name="coverImageURL"
        >
      </div>
      <div class="mb-4">
        <label for="title" class="form-label fw-semibold">
          Blog Title
        </label>

        <input 
          type="text"
          class="form-control form-control-lg"
          id="title"
          name="title"
          placeholder="Enter blog title"
        >

      </div>
      <div class="mb-4">

        <label for="body" class="form-label fw-semibold">
          Content
        </label>

        <textarea 
          class="form-control"
          id="body"
          name="body"
          rows="8"
          placeholder="Write your story..."
        ></textarea>

      </div>
      <button 
        type="submit"
        class="btn btn-dark btn-lg w-100">

        Publish Blog 🚀

      </button>
    </form>
  </div>
</div>
<%- include('./partials/scripts') %>
</body>

</html>