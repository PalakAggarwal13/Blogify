<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/head') %>
  <title><%= blog.title %> - Blogify</title>

  <style>

    body {
      background: #f8f9fa;
    }

    .blog-container {
      max-width: 850px;
    }

    .blog-title {
      font-size: 3rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .cover-image {
      width: 100%;
      max-height: 500px;
      object-fit: cover;
      border-radius: 20px;
    }

    .blog-content {
      font-size: 1.15rem;
      line-height: 1.8;
      white-space: pre-line;
    }

    .author-box {
      background: white;
      border-radius: 15px;
      padding: 20px;
    }

    .comment-box {
      background: white;
      border-radius: 15px;
      padding: 25px;
    }

    .comment {
      background: #f1f3f5;
      border-radius: 12px;
      padding: 15px;
    }

  </style>

</head>

<body>

<%- include('./partials/nav') %>
<div class="container blog-container mt-5">

  <!-- Blog Header -->
  <h1 class="blog-title">
    <%= blog.title %>
  </h1>

  <div class="text-muted mt-3 mb-4">
    By <b><%= blog.createdBy.fullName %></b>
  </div>

  <img 
    src="<%= blog.coverImageURL.startsWith('/') 
    ? blog.coverImageURL 
    : '/' + blog.coverImageURL %>"
    class="cover-image shadow"
  >

  <div class="mt-5 blog-content">

    <%= blog.body %>

  </div>

  <!-- Author -->

  <div class="author-box shadow mt-5 d-flex align-items-center">

    <img 
      src="<%= blog.createdBy.profileImageURL %>"
      width="70"
      height="70"
      class="rounded-circle me-3"
    >

    <div>

      <small class="text-muted">
        Written by
      </small>

      <h5 class="mb-0">
        <%= blog.createdBy.fullName %>
      </h5>

    </div>

  </div>

  <!-- Comments -->

  <div class="comment-box shadow mt-5">
    <h2 class="mb-4">
      Comments (<%= comments.length %>)
    </h2>
    <% if (locals.user) { %>
    <form action="/blog/comment/<%= blog._id %>" method="post">
      <textarea
        class="form-control mb-3"
        rows="3"
        name="content"
        placeholder="Write a comment..."
      ></textarea>


      <button class="btn btn-dark">
        Post Comment
      </button>


    </form>

    <% } %>
    <hr class="my-4">

    <% comments.forEach(comment => { %>
      <div class="comment mb-3 d-flex">
        <img 
          src="<%= comment.createdBy.profileImageURL %>"
          width="45"
          height="45"
          class="rounded-circle me-3"
        >
        <div>
          <strong>
            <%= comment.createdBy.fullName %>
          </strong>

          <p class="mb-0 mt-1">
            <%= comment.content %>
          </p>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<%- include('./partials/scripts') %>
</body>
</html>